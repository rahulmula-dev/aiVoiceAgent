# ─────────────────────────────────────────────────────────────────────────────
# Voice agent — environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── STT (Deepgram nova-3 streaming) ─────────────────────────────────────────
DEEPGRAM_API_KEY=""

# ── LLM (Groq for now; swap LLM_PROVIDER=openai/gemini when keys land) ──────
LLM_PROVIDER="groq"
GROQ_API_KEY=""

# Optional: enable when LLM_PROVIDER=gemini
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# ── TTS (ElevenLabs Flash) ──────────────────────────────────────────────────
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"  # Rachel — premade Free-tier voice

# ── Governance + RAG feature flags ──────────────────────────────────────────
GOVERNANCE_ENABLED="true"
RAG_ENABLED="false"
LOCAL_TEST="true"

# Postgres for pgvector RAG (only when RAG_ENABLED=true)
PG_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/voiceagent"

# When LOCAL_TEST=false, real Bedrock embeddings are used and these are needed:
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"

# ── Concurrency gate (Redis) ────────────────────────────────────────────────
CONCURRENCY_GATE_ENABLED="false"
REDIS_URL="redis://localhost:6379"
MAX_CONCURRENT_CALLS="5"
